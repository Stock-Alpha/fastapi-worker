[Unit]
Description=FastAPI Worker
After=network.target

[Service]
User=admin
WorkingDirectory=/home/admin/fastapi-worker
Environment="PATH=/home/admin/fastapi-worker/venv/bin"
ExecStart=/home/admin/fastapi-worker/venv/bin/uvicorn app.main:app \
  --host :: \
  --port 8000 \
  --workers 1 \
  --loop uvloop \
  --http h11 \
  --no-access-log
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
